            <mahapps:MetroTabItem>
                <TabItem.HeaderTemplate>
                    <ItemContainerTemplate>
                        <StackPanel Orientation="Horizontal">
                            <Viewbox Width="22.5"
                                    Height="26"
                                    Stretch="Fill">
                                <Path Fill="{DynamicResource MahApps.Brushes.Accent}"
                                        Data="{StaticResource DebugBadge}"
                                        RenderTransformOrigin="0.5,0.5">
                                    <Path.RenderTransform>
                                        <TransformGroup>
                                            <ScaleTransform/>
                                            <SkewTransform/>
                                            <RotateTransform/>
                                            <TranslateTransform X="-2.5"/>
                                        </TransformGroup>
                                    </Path.RenderTransform>
                                </Path>
                            </Viewbox>
                            <TextBlock FontSize="25"
                                    Text="{x:Static p:Strings.menu_debug}"
                                    HorizontalAlignment="Center"
                                    VerticalAlignment="Center"
                                    Margin="5,0,0,0"></TextBlock>
                        </StackPanel>
                    </ItemContainerTemplate>
                </TabItem.HeaderTemplate>
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition/>
                        <RowDefinition/>
                    </Grid.RowDefinitions>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="250"/>
                        <ColumnDefinition/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>
                    <DockPanel Grid.Row="0"
                            Grid.ColumnSpan="2">
                        <Menu DockPanel.Dock="Top">
                            <MenuItem Header="_File">
                                <MenuItem x:Name="SaveFile"
                                        Header="_Save GSI Output"
                                        Click="SaveFile_Click"/>
                            </MenuItem>
                            <MenuItem Header="_Debug settings"
                                    Click="DebugSettings_Click"/>
                            <MenuItem Header="Debug _info"
                                    Click="DebugInfo_Click"/>
                        </Menu>
                    </DockPanel>
                    <TextBlock x:Name="lastRecieveTime"
                            Text="Last recieve time from GSI"
                            Grid.Row="1"
                            Grid.ColumnSpan="2"
                            VerticalAlignment="Bottom"/>
                    <TextBox x:Name="outputBox"
                            IsReadOnly="True"
                            Text="None"
                            Grid.Row="2"
                            Grid.ColumnSpan="2"
                            VerticalScrollBarVisibility="Auto"/>
                    <TextBox x:Name="debugBox"
                            IsReadOnly="True"
                            Grid.Row="3"
                            Grid.ColumnSpan="3"
                            VerticalScrollBarVisibility="Auto"
                            TextChanged="DebugBox_TextChanged"
                            Loaded="DebugBox_Loaded"/>
                    <TextBlock x:Name="DebugPixelColor"
                            Text="Pixel Color at (x,y): res"
                            Grid.Row="1"
                            Grid.Column="2"
                            VerticalAlignment="Bottom"
                            Margin="0,0,0,15"/>
                    <TextBlock Text="Latest Captured Frame:"
                            Grid.Row="1"
                            Grid.Column="2"
                            VerticalAlignment="Bottom"
                            Margin="0,0,15,0"/>
                    <Border Grid.Row="2"
                            Grid.RowSpan="1"
                            Grid.Column="2"
                            BorderBrush="#FFABADB3"
                            BorderThickness="1">
                        <Image x:Name="latestCapturedFrame"/>
                    </Border>
                    <TextBox x:Name="csConsoleOutput"
                            IsReadOnly="True"
                            Grid.Row="2"
                            Grid.RowSpan="2"
                            Grid.Column="2"
                            VerticalScrollBarVisibility="Auto"
                            Visibility="Hidden"/>
                </Grid>
            </mahapps:MetroTabItem>
            <mahapps:MetroTabItem>
                <TabItem.HeaderTemplate>
                    <ItemContainerTemplate>
                        <StackPanel Orientation="Horizontal">
                            <Viewbox Width="25"
                                    Height="25"
                                    Stretch="Fill">
                                <Path Fill="{DynamicResource MahApps.Brushes.Accent}"
                                        Data="{StaticResource InfoBadge}"
                                        RenderTransformOrigin="0.5,0.5">
                                    <Path.RenderTransform>
                                        <TransformGroup>
                                            <ScaleTransform/>
                                            <SkewTransform/>
                                            <RotateTransform/>
                                            <TranslateTransform X="-3.5"/>
                                        </TransformGroup>
                                    </Path.RenderTransform>
                                </Path>
                            </Viewbox>
                            <TextBlock FontSize="25"
                                    Text="{x:Static p:Strings.menu_about}"
                                    HorizontalAlignment="Center"
                                    VerticalAlignment="Center"
                                    Margin="5,0,0,0"></TextBlock>
                        </StackPanel>
                    </ItemContainerTemplate>
                </TabItem.HeaderTemplate>
                <Grid>
                    <Border BorderBrush="{DynamicResource MahApps.Brushes.Accent}"
                            BorderThickness="2"
                            CornerRadius="8"
                            Background="#1E1E1E"
                            MinWidth="300"
                            VerticalAlignment="Center"
                            HorizontalAlignment="Center"
                            Padding="40,35">

                        <StackPanel HorizontalAlignment="Center"
                                VerticalAlignment="Center">

                            <Image Source="/Images/App_Icon.png"
                                   Width="64"
                                   Height="64"
                                   Margin="0,0,0,20"
                                   RenderOptions.BitmapScalingMode="HighQuality"
                                   UseLayoutRounding="True"
                                   SnapsToDevicePixels="True"/>

                            <TextBlock Text="CSAuto"
                                       FontSize="48"
                                       FontWeight="Bold"
                                       Foreground="White"
                                       HorizontalAlignment="Center"
                                       Margin="0,0,0,12"/>

                            <TextBlock Text="{x:Static p:Strings.text_description}"
                                       Foreground="#B0B0B0"
                                       HorizontalAlignment="Center"
                                       TextAlignment="Center"
                                       FontSize="24"
                                       TextWrapping="WrapWithOverflow"
                                       Margin="0,0,0,25"/>

                            <Border Height="1"
                                    Background="#404040"
                                    Margin="0,0,0,20"
                                    HorizontalAlignment="Stretch"/>

                            <TextBlock HorizontalAlignment="Center"
                                       FontSize="20"
                                       TextAlignment="Center"
                                       TextWrapping="WrapWithOverflow">

                                <Hyperlink Click="AboutLicense_Click"
                                                TextDecorations="None">
                                    <Run Text="Copyright © 2023, Murky"/>
                                    <Hyperlink.Style>
                                        <Style TargetType="Hyperlink">
                                            <Setter Property="Foreground"
                                                                    Value="#909090"/>
                                            <Setter Property="Cursor"
                                                                    Value="Hand"/>
                                            <Style.Triggers>
                                                <Trigger Property="IsMouseOver"
                                                                        Value="True">
                                                    <Setter Property="Foreground"
                                                                            Value="{DynamicResource MahApps.Brushes.Accent}"/>
                                                </Trigger>
                                            </Style.Triggers>
                                        </Style>
                                    </Hyperlink.Style>
                                </Hyperlink>
                                
                            </TextBlock>

                        </StackPanel>
                    </Border>
                </Grid>
            </mahapps:MetroTabItem>
        </TabControl>
    </Grid>
</mahapps:MetroWindow>